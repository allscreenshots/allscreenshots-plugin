{
  "mcpServers": {
    "allscreenshots": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "fastmcp>=2.0",
        "--with",
        "httpx>=0.27",
        "fastmcp",
        "run",
        "./mcp_server/server.py"
      ],
      "cwd": ".",
      "env": {
        "ALLSCREENSHOTS_API_KEY": ""
      }
    }
  }
}
