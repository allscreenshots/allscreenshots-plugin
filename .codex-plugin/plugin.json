    "developerName": "Allscreenshots",
    "category": "Productivity",
    "capabilities": [
      "Read",
      "Write"
    ],
    "websiteURL": "https://allscreenshots.com",
    "defaultPrompt": [
      "Take a screenshot of https://example.com",
      "Capture a full-page screenshot of this site in dark mode.",
      "Get Allscreenshots API setup information."
    ],
    "brandColor": "#2563EB"
  }
