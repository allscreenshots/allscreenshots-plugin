{
  "name": "allscreenshots",
  "version": "1.0.0",
  "description": "Take website screenshots via the Allscreenshots API.",
  "author": {
    "name": "Allscreenshots",
    "url": "https://allscreenshots.com"
  },
  "homepage": "https://allscreenshots.com",
  "repository": "https://github.com/allscreenshots/allscreenshots-plugin",
  "license": "MIT",
  "keywords": [
    "screenshots",
    "websites",
    "mcp",
    "browser-automation"
  ],
  "mcpServers": "./.mcp.json",
  "interface": {
    "displayName": "Allscreenshots",
